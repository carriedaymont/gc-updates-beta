inst/doc
packrat/lib*/
packrat/src/

*.swo
*.swp
output
.Rproj.user
.Rprofile

# pkgdown site (generated output — regenerate with pkgdown::build_site() at release)
docs/

# Claude Code local settings
.claude/

# Local test-review CSV artifacts (regenerate with scripts/dump_test_diffs.R)
test-review/

# Ephemeral scratch (regenerable; not shared)
scratch/

# Funding/usability hours tracking (administrative; not for the repo)
dev/notes/shiny-wrapper-hours.md

# Regenerable run artifacts (checkpoint chunks, run logs, dev figures)
gc-checkpoints/
gc_run.log
dev/figures/

